all:
  hosts:
    localhost:
      ansible_connection: local
  children:
    vm:
      hosts:
        cp2-vm:
          ansible_host: "{{ vm_ip }}"
          ansible_user: azureuser
          ansible_ssh_private_key_file: "{{ ssh_key | default('~/.ssh/cp2_azure') }}"
          ansible_python_interpreter: /usr/bin/python3
          ansible_become: yes
